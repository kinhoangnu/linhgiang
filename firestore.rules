rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function householdPath(householdId) {
      return /databases/$(database)/documents/households/$(householdId);
    }

    function isHouseholdMember(householdId) {
      return signedIn()
        && exists(householdPath(householdId))
        && request.auth.uid in get(householdPath(householdId)).data.memberIds;
    }

    function isCreatingOwnHousehold() {
      return signedIn()
        && request.resource.data.memberIds is list
        && request.resource.data.memberIds.hasOnly([request.auth.uid])
        && request.resource.data.memberIds.hasAll([request.auth.uid])
        && request.resource.data.updatedBy == request.auth.uid;
    }

    function isSelfJoiningHousehold() {
      return signedIn()
        && resource.data.memberIds is list
        && !(request.auth.uid in resource.data.memberIds)
        && resource.data.memberIds.size() < 2
        && request.resource.data.memberIds is list
        && request.resource.data.memberIds.size() == resource.data.memberIds.size() + 1
        && request.resource.data.memberIds.hasAll(resource.data.memberIds)
        && request.auth.uid in request.resource.data.memberIds
        && request.resource.data.updatedBy == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "memberIds",
          "updatedAt",
          "updatedBy"
        ]);
    }

    match /households/{householdId} {
      allow create: if isCreatingOwnHousehold();
      allow read, delete: if isHouseholdMember(householdId);
      allow update: if isHouseholdMember(householdId) || isSelfJoiningHousehold();

      match /members/{memberId} {
        allow read, write: if isHouseholdMember(householdId);
      }

      match /chores/{choreId} {
        allow read, write: if isHouseholdMember(householdId);
      }

      match /taskProfiles/{profileId} {
        allow read, write: if isHouseholdMember(householdId);
      }

      match /choreCompletions/{completionId} {
        allow read, write: if isHouseholdMember(householdId);
      }

      match /shoppingItems/{itemId} {
        allow read, write: if isHouseholdMember(householdId);
      }

      match /priceObservations/{observationId} {
        allow read, write: if isHouseholdMember(householdId);
      }

      match /stores/{storeId} {
        allow read, write: if isHouseholdMember(householdId);
      }

      match /settings/{settingId} {
        allow read, write: if isHouseholdMember(householdId);
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
